# ─────────────────────────────────────────
#  Dream Life Mapping — Environment Variables
#  Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────

# Kit (ConvertKit) — your form ID for email capture
# Find this in Kit → Forms → select form → grab the ID from the URL
NEXT_PUBLIC_KIT_FORM_ID=

# Checkout URL — where CTA buttons send people to buy
# This could be a Circle checkout link, Stripe payment link, or ThriveCart URL
NEXT_PUBLIC_CHECKOUT_URL=

# Payment plan checkout URL (if different from full-pay)
NEXT_PUBLIC_CHECKOUT_URL_PLAN=

# Meta Pixel ID (optional — for Facebook/Instagram ad tracking)
NEXT_PUBLIC_META_PIXEL_ID=

# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# Kit API Secret — needed for server-side tag operations
# (e.g. tagging "dlm-webinar-watched" when someone visits /workshop)
# Find this in Kit → Settings → Developer → API Secret
KIT_API_SECRET=
